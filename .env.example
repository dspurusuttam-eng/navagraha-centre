DATABASE_URL="postgresql://postgres:postgres@localhost:5432/navagraha_centre?schema=public"
BETTER_AUTH_SECRET="replace-with-a-generated-secret"
# Canonical auth origin for production (recommended: www domain).
BETTER_AUTH_URL="http://localhost:3000"
# Comma-separated list of trusted auth origins. In production include both apex + www.
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Optional password-recovery mail sender (recommended for production)
RESEND_API_KEY=""
AUTH_RESET_FROM_EMAIL=""
# mock-deterministic | circular-natal-real
ASTROLOGY_PROVIDER="mock-deterministic"
# mock-curated | openai-responses
AI_PROVIDER="mock-curated"
AI_USAGE_LOGGING="false"
OPENAI_API_KEY=""
OPENAI_MODEL=""
# Canonical public site URL for metadata/canonical tags (recommended: www domain in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="NAVAGRAHA CENTRE"
NEXT_PUBLIC_ANALYTICS_ENABLED="false"
NEXT_PUBLIC_OBSERVABILITY_ENDPOINT="/api/observability/web-vitals"
SITE_URL="http://localhost:3000"
# Security + abuse protection (Phase 18.1N)
RATE_LIMIT_ENABLED="true"
AI_RATE_LIMIT_ENABLED="true"
SECURITY_ALLOWED_ORIGINS="http://localhost:3000"
SECURITY_MAX_JSON_BYTES="20000"
SECURITY_MAX_PROMPT_LENGTH="1200"
SECURITY_MAX_MESSAGE_LENGTH="700"
CONTACT_FORM_RATE_LIMIT="10"
CONSULTATION_RATE_LIMIT="5"
REPORT_REQUEST_RATE_LIMIT="8"
SPAM_HONEYPOT_FIELD="company"
SPAM_STARTED_AT_FIELD="startedAt"
SPAM_MIN_SUBMIT_MS="800"
SECURITY_ENABLE_CSP="true"
SECURITY_CSP_REPORT_ONLY="false"
ADMIN_EMAILS=""
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_ENFORCE="false"
TURNSTILE_VERIFY_ENDPOINT="https://challenges.cloudflare.com/turnstile/v0/siteverify"
# Monetization readiness (Phase 18.1M)
NEXT_PUBLIC_ENABLE_ADSENSE="false"
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=""
NEXT_PUBLIC_ADSENSE_DEFAULT_SLOT_ID=""
NEXT_PUBLIC_ENABLE_MONETIZATION_TRACKING="false"
NEXT_PUBLIC_ENABLE_AD_PLACEHOLDERS="true"
NEXT_PUBLIC_ENABLE_CONSULTATION_CTA="true"
NEXT_PUBLIC_ENABLE_REPORT_CTA="true"
NEXT_PUBLIC_ENABLE_SHOP_CTA="true"
NEXT_PUBLIC_ENABLE_PREMIUM_AI_CTA="true"
NEXT_PUBLIC_ENABLE_AFFILIATE_LINKS="false"
NEXT_PUBLIC_SUPPORTED_CURRENCIES="INR,USD"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# Ops monitoring + alerting (optional but recommended for launch)
OPS_ALERTS_ENABLED="false"
OPS_ALERT_WEBHOOK_URL=""
OPS_ALERT_ON_WARNINGS="false"
OPS_HEALTHCHECK_URL=""
OPS_HEALTHCHECK_TIMEOUT_MS="15000"
SMOKE_BASE_URL="http://localhost:3000"
# Astrology birth-context resolution (Phase 15.1B/15.1C)
# Used for place geocoding + timezone lookup from birthplace coordinates
GEOCODING_PROVIDER="opencage"
GEOCODING_API_KEY=""
# Legacy fallback for local compatibility (optional; GEOCODING_API_KEY is preferred)
OPENCAGE_API_KEY=""
# Commerce / checkout (Phase 10)
# draft-order | stripe | razorpay (razorpay is provider-boundary ready)
SHOP_CHECKOUT_PROVIDER="draft-order"
# Required for webhook signature verification (use a long random secret value)
SHOP_DRAFT_WEBHOOK_SECRET=""
# Optional shared fallback secret (also read by draft provider if set)
SHOP_WEBHOOK_SECRET=""
# Razorpay (required when SHOP_CHECKOUT_PROVIDER=razorpay)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
