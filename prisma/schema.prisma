generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChartType {
  NATAL
  TRANSIT
  COMPATIBILITY
  SOLAR_RETURN
}

enum ChartStatus {
  DRAFT
  READY
  ARCHIVED
}

enum ConsultationType {
  PRIVATE_READING
  COMPATIBILITY
  BUSINESS_ASTROLOGY
  REMEDY_GUIDANCE
  FOLLOW_UP
}

enum ConsultationStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ConsultationSlotStatus {
  OPEN
  BOOKED
  CANCELLED
}

enum InquiryType {
  GENERAL_INQUIRY
  CONSULTATION_READY
  COMPATIBILITY_FOCUSED
  REMEDY_FOCUSED
  RETURNING_FOLLOW_UP
}

enum InquiryUrgencyLevel {
  LOW
  STANDARD
  ELEVATED
}

enum InquiryLifecycleStage {
  NEW_INQUIRY
  CONSULTATION_INTEREST
  AWAITING_RESPONSE
  BOOKED
  POST_SESSION
  FOLLOW_UP_ELIGIBLE
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductCategory {
  RUDRAKSHA
  MALAS
  GEMSTONES
  YANTRAS
  IDOLS
  MANTRA_REMEDIES
}

enum OrderStatus {
  DRAFT
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  MANUAL_PLACEHOLDER
  STRIPE
}

enum PaymentStatus {
  NOT_STARTED
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum RemedyType {
  MANTRA
  RUDRAKSHA
  MALA
  GEMSTONE
  YANTRA
  PUJA
  DONATION
  FASTING
  SPIRITUAL_DISCIPLINE
  LIFESTYLE_SUPPORT
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum AiPromptArea {
  REPORT_INTERPRETATION
}

enum AiPromptVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AiConversationStatus {
  ACTIVE
  ARCHIVED
}

enum AiMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum AiTaskKind {
  CHART_EXPLANATION
  TRANSIT_EXPLANATION
  REMEDY_EXPLANATION
  CONSULTATION_BRIEF_GENERATION
  CONTENT_DRAFT_GENERATION
}

enum AiTaskRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  profile          Profile?
  birthData        BirthData[]
  charts           Chart[]
  consultations    Consultation[]
  orders           Order[]
  subscriptions    Subscription[]
  authoredArticles Article[]
  adminAssignments AdminRoleAssignment[]
  auditEntries     AuditLog[]            @relation("AuditActor")
  aiConversations  AiConversationSession[]
  aiTaskRuns       AiTaskRun[]
  inquiryLeads     InquiryLead[]
  inquiryLifecycleEvents InquiryLifecycleEvent[] @relation("InquiryLifecycleActor")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  preferredLanguage String?
  dob       String?
  tob       String?
  city      String?
  region    String?
  country   String?
  timezone  String?
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)
  chartData Json?
  bio       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile")
}

model BirthData {
  id        String   @id @default(cuid())
  userId    String
  label     String
  birthDate String
  birthTime String?
  timezone  String
  city      String
  region    String?
  country   String
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  charts    Chart[]
  consultations Consultation[]

  @@index([userId, isPrimary])
  @@map("birth_data")
}

model ConsultationPackage {
  id              String         @id @default(cuid())
  slug            String         @unique
  type            ConsultationType
  title           String
  summary         String
  description     String?
  durationMinutes Int
  priceFromMinor  Int?
  currencyCode    String         @default("INR")
  isFeatured      Boolean        @default(false)
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  consultations   Consultation[]

  @@index([isActive, sortOrder])
  @@map("consultation_package")
}

model ConsultationSlot {
  id           String                 @id @default(cuid())
  startsAt     DateTime
  endsAt       DateTime
  timezone     String                 @default("Asia/Kolkata")
  status       ConsultationSlotStatus @default(OPEN)
  note         String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  consultation Consultation?

  @@index([status, startsAt])
  @@map("consultation_slot")
}

model Chart {
  id                 String      @id @default(cuid())
  userId             String
  birthDataId        String
  type               ChartType
  status             ChartStatus @default(DRAFT)
  providerKey        String      @default("deterministic-placeholder")
  calculationVersion String?
  chartPayload       Json?
  generatedAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthData          BirthData   @relation(fields: [birthDataId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("chart")
}

model Consultation {
  id             String             @id @default(cuid())
  userId         String
  birthDataId    String?
  packageId      String?
  slotId         String?            @unique
  type           ConsultationType
  status         ConsultationStatus @default(REQUESTED)
  confirmationCode String           @unique
  astrologerName String             @default("Joy Prakash Sarmah")
  serviceLabel   String
  scheduledFor   DateTime?
  scheduledEnd   DateTime?
  durationMinutes Int?
  clientTimezone String?
  preferredLanguage String?
  contactPhone   String?
  topicFocus     String?
  intakeSummary  String?
  internalNotes  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthData      BirthData?         @relation(fields: [birthDataId], references: [id], onDelete: SetNull)
  package        ConsultationPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  slot           ConsultationSlot?  @relation(fields: [slotId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, scheduledFor])
  @@map("consultation")
}

model InquiryLead {
  id                 String                @id @default(cuid())
  userId             String?
  fullName           String
  email              String
  phone              String?
  timezone           String?
  inquiryType        InquiryType
  urgencyLevel       InquiryUrgencyLevel   @default(STANDARD)
  desiredServiceSlug String?
  message            String
  sourcePath         String?
  lifecycleStage     InquiryLifecycleStage
  lastLifecycleAt    DateTime              @default(now())
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  lifecycleEvents    InquiryLifecycleEvent[]

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([lifecycleStage, updatedAt])
  @@map("inquiry_lead")
}

model InquiryLifecycleEvent {
  id          String                @id @default(cuid())
  leadId      String
  fromStage   InquiryLifecycleStage?
  toStage     InquiryLifecycleStage
  note        String?
  actorUserId String?
  createdAt   DateTime              @default(now())
  lead        InquiryLead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor       User?                 @relation("InquiryLifecycleActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([toStage, createdAt])
  @@index([actorUserId, createdAt])
  @@map("inquiry_lifecycle_event")
}

model Product {
  id             String             @id @default(cuid())
  slug           String             @unique
  sku            String             @unique
  name           String
  summary        String
  description    String?
  category       ProductCategory
  type           ProductType
  status         ProductStatus      @default(DRAFT)
  priceInMinor   Int?
  currencyCode   String             @default("INR")
  imageUrl       String?
  badge          String?
  materialLabel  String?
  ritualFocus    String?
  inventoryCount Int?
  isFeatured     Boolean            @default(false)
  sortOrder      Int                @default(0)
  metadata       Json?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  orderItems     OrderItem[]
  remedyLinks    RemedyProductLink[]

  @@index([status, category, sortOrder])
  @@map("product")
}

model Order {
  id                String          @id @default(cuid())
  userId            String?
  orderNumber       String          @unique
  status            OrderStatus     @default(DRAFT)
  paymentProvider   PaymentProvider @default(MANUAL_PLACEHOLDER)
  paymentStatus     PaymentStatus   @default(NOT_STARTED)
  checkoutReference String?         @unique
  currencyCode      String          @default("INR")
  subtotalAmount    Int             @default(0)
  taxAmount         Int             @default(0)
  shippingAmount    Int             @default(0)
  totalAmount       Int             @default(0)
  billingName       String?
  customerEmail     String?
  customerPhone     String?
  billingTimezone   String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  paymentRecords    PaymentRecord[]
  subscriptions     Subscription[]

  @@index([userId, status])
  @@map("order")
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  planId          String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  nextBillingDate DateTime?
  endDate         DateTime?
  sourceOrderId   String?            @unique
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceOrder     Order?             @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([planId, status])
  @@map("subscription")
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  productId        String?
  titleSnapshot    String
  skuSnapshot      String?
  categorySnapshot ProductCategory?
  unitAmount       Int             @default(0)
  quantity         Int             @default(1)
  createdAt        DateTime        @default(now())
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_item")
}

model PaymentRecord {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider @default(MANUAL_PLACEHOLDER)
  status            PaymentStatus   @default(NOT_STARTED)
  amount            Int             @default(0)
  currencyCode      String          @default("INR")
  providerReference String?
  redirectUrl       String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@map("payment_record")
}

model Remedy {
  id           String              @id @default(cuid())
  slug         String              @unique
  title        String
  summary      String
  description  String?
  type         RemedyType
  cautionNote  String?
  isFeatured   Boolean             @default(false)
  publishedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  productLinks RemedyProductLink[]

  @@map("remedy")
}

model RemedyProductLink {
  id               String   @id @default(cuid())
  remedyId         String
  productId        String
  relationshipNote String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  remedy           Remedy   @relation(fields: [remedyId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([remedyId, productId])
  @@index([productId, sortOrder])
  @@map("remedy_product_link")
}

model RemedyRecommendationRun {
  id                     String   @id @default(cuid())
  userId                 String?
  chartRecordId          String?
  surfaceKey             String
  inputHash              String?
  signalKeys             String[]
  topRecommendationSlugs String[]
  recommendationSnapshot Json
  createdAt              DateTime @default(now())

  @@index([userId, createdAt])
  @@index([chartRecordId, createdAt])
  @@index([surfaceKey, createdAt])
  @@map("remedy_recommendation_run")
}

model AstrologerCopilotSnapshot {
  id                  String   @id @default(cuid())
  consultationId      String
  astrologerUserId    String
  providerKey         String
  model               String?
  promptTemplateKey   String?
  promptVersionLabel  String?
  inputHash           String?
  snapshotPayload     Json
  briefText           String
  followUpDraft       String
  recapDraft          String
  astrologerNotesDraft String
  copyCount           Int      @default(0)
  exportCount         Int      @default(0)
  lastCopiedAt        DateTime?
  lastExportedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([consultationId, createdAt])
  @@index([astrologerUserId, createdAt])
  @@map("astrologer_copilot_snapshot")
}

model Article {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  excerpt        String
  body           String?
  status         ArticleStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  authorId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@map("article")
}

model AiPromptTemplate {
  id              String          @id @default(cuid())
  key             String          @unique
  title           String
  description     String?
  area            AiPromptArea    @default(REPORT_INTERPRETATION)
  activeVersionId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  activeVersion   AiPromptVersion? @relation("PromptTemplateActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  versions        AiPromptVersion[] @relation("PromptTemplateVersions")

  @@map("ai_prompt_template")
}

model AiPromptVersion {
  id                 String               @id @default(cuid())
  templateId         String
  version            Int
  label              String
  model              String?
  systemPrompt       String
  userPrompt         String
  status             AiPromptVersionStatus @default(DRAFT)
  releaseNotes       String?
  activatedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  template           AiPromptTemplate     @relation("PromptTemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  activeForTemplates AiPromptTemplate[]   @relation("PromptTemplateActiveVersion")
  taskRuns           AiTaskRun[]

  @@unique([templateId, version])
  @@index([templateId, status])
  @@map("ai_prompt_version")
}

model AiConversationSession {
  id         String               @id @default(cuid())
  userId     String?
  channelKey String               @default("dashboard")
  title      String?
  status     AiConversationStatus @default(ACTIVE)
  context    Json?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  archivedAt DateTime?
  user       User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages   AiConversationMessage[]
  taskRuns   AiTaskRun[]

  @@index([userId, status, updatedAt])
  @@map("ai_conversation_session")
}

model AiConversationMessage {
  id          String                @id @default(cuid())
  sessionId   String
  role        AiMessageRole
  content     String
  toolName    String?
  toolPayload Json?
  model       String?
  providerKey String?
  createdAt   DateTime              @default(now())
  session     AiConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("ai_conversation_message")
}

model AiTaskRun {
  id                 String               @id @default(cuid())
  sessionId          String?
  userId             String?
  taskKind           AiTaskKind
  status             AiTaskRunStatus      @default(QUEUED)
  providerKey        String
  model              String?
  promptTemplateKey  String?
  promptVersionId    String?
  promptVersionLabel String?
  inputHash          String?
  inputPayload       Json?
  outputPayload      Json?
  normalizedOutput   Json?
  policyPassed       Boolean              @default(true)
  policyViolations   Json?
  usageInputTokens   Int?
  usageOutputTokens  Int?
  usageTotalTokens   Int?
  errorMessage       String?
  startedAt          DateTime             @default(now())
  completedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  session            AiConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user               User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  promptVersion      AiPromptVersion?     @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@index([userId, taskKind, createdAt])
  @@index([sessionId, createdAt])
  @@index([promptTemplateKey, createdAt])
  @@map("ai_task_run")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorRoleKey String?
  entityType  String
  entityId    String
  action      String
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_log")
}

model AdminRole {
  id          String                @id @default(cuid())
  key         String                @unique
  name        String
  description String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  assignments AdminRoleAssignment[]

  @@map("admin_role")
}

model AdminRoleAssignment {
  id        String    @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("admin_role_assignment")
}
